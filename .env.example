# RAG Chatbot Lab — Configuration
#
# Copy this file to .env and uncomment the API key(s) you have.
# Anything you don't uncomment is left as the built-in default and the
# corresponding LLM provider is simply not available.
# ==============================================

# ---------------------------------------------
# 1. Pick at least one LLM provider
# ---------------------------------------------
# Uncomment (and paste your key after the =) any provider you want to use.
# Hugging Face is the easiest to start with: free tier, no billing needed.

#HF_TOKEN=hf_...                            # Hugging Face (Router API; default)
#HUGGINGFACE_API_KEY=hf_...                 # alternative name for the same key

#OPENAI_API_KEY=sk-...
#OPENAI_MODEL=gpt-4o-mini

#ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_MODEL=claude-3-haiku-20240307

#DEEPSEEK_API_KEY=...
#DEEPSEEK_MODEL=deepseek-chat

#GROK_API_KEY=...
#GROK_MODEL=grok-beta

#KIMI_API_KEY=...
#KIMI_MODEL=moonshot-v1-8k

#MINIMAX_API_KEY=...
#MINIMAX_MODEL=abab6.5-chat

#QWEN_API_KEY=...
#QWEN_MODEL=qwen-plus

#GLM_API_KEY=...
#GLM_MODEL=glm-4

# Ollama runs locally — point to your server instead of using a key:
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_MODEL=llama2

# ---------------------------------------------
# 2. (Optional) Pick the default provider at startup
# ---------------------------------------------
# One of: huggingface, openai, anthropic, deepseek, grok, kimi, minimax, qwen, glm, ollama
DEFAULT_LLM_PROVIDER=huggingface

# ---------------------------------------------
# 3. (Optional) Where files live
# ---------------------------------------------
KNOWLEDGE_BASE_PATH=./knowledge_base/        # your own docs — no bundled sample, add at least one
SAMPLE_CORPUS_PATH=./examples/                # optional fallback corpus dir; unused unless you add one
PROMPTS_DIR=./prompts/                       # the prompt .txt files
VECTOR_STORE_PATH=./data/embeddings/         # FAISS index built by setup
PROCESSED_TEXTS_PATH=./data/processed_texts/

# ---------------------------------------------
# 4. (Optional) Tune the model and retrieval
# ---------------------------------------------
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
DEVICE=cpu                                   # cpu or cuda

TEMPERATURE=0.7
MAX_CONTEXT_LENGTH=6144
MAX_RESPONSE_LENGTH=8192

RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.4
CHUNK_SIZE=512
CHUNK_OVERLAP=50
